# API Port Configuration (Python backend)
API_PORT=5000
API_HOST=localhost

# Environment
NODE_ENV=development

# Python configuration
PYTHONUNBUFFERED=1

# Expo configuration
EXPO_USE_FAST_REFRESH=true

# API Service URLs (for your Expo app to use)
# The API service will auto-detect the correct URL based on platform/environment
# Only override if you need to force a specific URL
EXPO_PUBLIC_API_URL=

# Production API URL (used when NODE_ENV=production)
# Update this with your actual deployed API endpoint
EXPO_PUBLIC_PRODUCTION_API_URL=https://appdev---pathonet.web.app

# Analytics Configuration (optional)
ANALYTICS_ENDPOINT_URL=
ANALYTICS_API_KEY=

# Firebase Configuration (required)
# Get these from Firebase Console → Project Settings → General
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=appdev---pathonet.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=appdev---pathonet
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=appdev---pathonet.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id
