{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": {
    "source": "api",
    "runtime": "python39"
  },
  "auth": {
    "providers": [
      {
        "email": {
          "enabled": true,
          "requireDisplayName": false
        }
      }
    ]
  }
}