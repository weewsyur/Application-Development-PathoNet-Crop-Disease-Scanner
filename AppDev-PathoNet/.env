# PathoNet API Server Configuration
# Set this to your Flask server URL
# For Android emulator: http://10.0.2.2:5000
# For iOS simulator: http://localhost:5000
# For physical device: http://YOUR_MACHINE_IP:5000 (e.g., http://192.168.1.10:5000)
# For web/local development: http://localhost:5000
EXPO_PUBLIC_API_URL=http://localhost:5000

# Analytics Configuration
# Set to your analytics endpoint URL (e.g., Mixpanel, Google Analytics, or custom)
# Leave empty to disable analytics
ANALYTICS_ENDPOINT_URL=
ANALYTICS_API_KEY=
