{
  "name": "appdev-pathonet",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start:api": "node scripts/start_api.js",
    "start-api": "npm run start:api",
    "start": "concurrently -n API,EXPO -c cyan,green \"npm run start:api\" \"expo start\"",
    "android": "concurrently -n API,EXPO -c cyan,green \"npm run start:api\" \"expo start --android\"",
    "ios": "concurrently -n API,EXPO -c cyan,green \"npm run start:api\" \"expo start --ios\"",
    "web": "concurrently -n API,EXPO -c cyan,green \"npm run start:api\" \"expo start --web\"",
    "start:dev": "concurrently -n API,EXPO -c cyan,green \"npm run start:api\" \"expo start\"",
    "stop": "npm run kill-processes",
    "kill-processes": "node scripts/kill-processes.js",
    "reset-project": "node ./scripts/reset-project.js",
    "lint": "expo lint",
    "setup:python": "node scripts/install-python-deps.js",
    "setup:python:bat": "python setup-python-env.bat",
    "setup:python:unix": "bash setup-python-env.sh",
    "server": "python run_api_server.py",
    "server:check": "curl -s http://localhost:5000/health/v2 || echo 'Server is not running'",
    "server:auto": "node scripts/auto-start-api.js",
    "server:stop": "node scripts/stop-api.js",
    "service:install": "node scripts/install-service.js",
    "build": "expo export -p web",
    "build:firebase": "expo export -p web && firebase deploy --only hosting",
    "deploy": "firebase deploy",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "expo": "^55.0.23",
    "expo-constants": "~55.0.0",
    "expo-file-system": "~55.0.17",
    "expo-font": "~55.0.6",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linking": "~55.0.15",
    "expo-router": "~55.0.14",
    "expo-splash-screen": "~55.0.20",
    "expo-status-bar": "~55.0.6",
    "expo-symbols": "~55.0.8",
    "expo-system-ui": "~55.0.17",
    "expo-web-browser": "~55.0.15",
    "feather-icons": "^4.29.2",
    "firebase": "^12.13.0",
    "lucide-react": "^1.14.0",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-css": "^3.0.7",
    "react-native-feather": "^1.1.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.7.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.2.10",
    "concurrently": "^9.2.1",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~55.0.0",
    "expo-build-properties": "^55.0.13",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  },
  "private": true
}
